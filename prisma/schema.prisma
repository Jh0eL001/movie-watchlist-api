// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * model es donde diseñas la estructura de tus datos,
 * que luego Prisma transformará en una tabla real en tu base de datos de Neon.
 */
model User {
  id        String   @id @default(uuid()) //Primary Key 🔑 Generador de ID(el uuid())
  name      String
  email     String   @unique // unique porque 2 users no pueden tener el mismo email
  password  String
  //Timestamp Guarda la fecha y hora.
  createdAt DateTime @default(now()) //Al crear el usuario, la DB pone la hora exacta de ese momento sin que tú hagas nada.

  // Relations
  movies         Movie[]         @relation("MovieCreator")
  watchlistItems WatchlistItem[]
}

//Atributos (@): Todo lo que empieza con @ son instrucciones especiales para la base de datos (modificadores).
// ***** COMO ENVIAR ESTO A PRISMA: npx prisma migrate dev --name 

// ***************************************** MOVIE TABLE *****************************************
model Movie {
  id          String   @id @default(uuid())
  title       String
  overview    String? // "?"" is for optional att
  releaseYear Int
  genres      String[] @default([])
  runtime     Int?
  posterUrl   String?
  createdBy   String
  createdAt   DateTime @default(now())

  // Relation
  creator        User            @relation("MovieCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  watchlistItems WatchlistItem[]
}

model WatchlistItem {
  id        String          @id @default(uuid())
  userId    String
  movieId   String
  status    WatchlistStatus @default(PLANNED) // custom enum defined down
  rating    Int?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

enum WatchlistStatus {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}
